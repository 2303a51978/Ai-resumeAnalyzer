{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/analyze",
      "dest": "api/index.py"
    },
    {
      "src": "/login",
      "dest": "api/index.py"
    },
    {
      "src": "/register",
      "dest": "api/index.py"
    },
    {
      "src": "/logout",
      "dest": "api/index.py"
    },
    {
      "src": "/resumes",
      "dest": "api/index.py"
    },
    {
      "src": "/stats",
      "dest": "api/index.py"
    },
    {
      "src": "/auth/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*\\.(js|css|json|png|jpg|jpeg|svg|gif|webp|ico))",
      "dest": "/frontend/$1"
    },
    {
      "src": "/",
      "dest": "/frontend/index.html"
    }
  ]
}
