{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/analyze",
      "methods": ["POST"],
      "dest": "api/index.py"
    },
    {
      "src": "/login",
      "dest": "api/index.py"
    },
    {
      "src": "/register",
      "dest": "api/index.py"
    },
    {
      "src": "/logout",
      "dest": "api/index.py"
    },
    {
      "src": "/resumes",
      "dest": "api/index.py"
    },
    {
      "src": "/stats",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*\\.(js|css|json|html|png|jpg|jpeg|svg|gif|webp|ico))",
      "dest": "frontend/$1"
    },
    {
      "src": "/",
      "dest": "frontend/index.html"
    }
  ]
}
